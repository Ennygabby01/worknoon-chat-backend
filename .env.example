NODE_ENV=development
HOST=0.0.0.0
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/worknoon_chat
JWT_ACCESS_SECRET=generate-a-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_COOKIE_NAME=worknoon_refresh_token
REFRESH_TOKEN_EXPIRES_DAYS=7
CORS_ORIGIN=http://localhost:3000
APP_ORIGIN=http://localhost:3000
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=Worknoon Chat <no-reply@worknoon.local>

# Required only when running `npm run seed:admin`
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_NAME=Worknoon Admin
SEED_ADMIN_PASSWORD=change-this-local-admin-password

# Required only when running `npm run seed:agents`
SEED_AGENT_PASSWORD=change-this-local-agent-password
SEED_AGENT_1_EMAIL=agent1@worknoon.dev
SEED_AGENT_1_NAME=Alex Rivera
SEED_AGENT_2_EMAIL=agent2@worknoon.dev
SEED_AGENT_2_NAME=Jordan Lee
SEED_AGENT_3_EMAIL=agent3@worknoon.dev
SEED_AGENT_3_NAME=Sam Okafor

# Required only when running `npm run seed:demo`
SEED_DEMO_PASSWORD=change-this-local-demo-password
